[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/title_screen.gd" id="1"]

[node name="TitleScreen" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1")

[node name="Margin" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/margin_left = 120
theme_override_constants/margin_top = 120
theme_override_constants/margin_right = 120
theme_override_constants/margin_bottom = 120

[node name="VBox" type="VBoxContainer" parent="Margin"]
layout_mode = 2
theme_override_constants/separation = 24

[node name="Title" type="Label" parent="Margin/VBox"]
layout_mode = 2
text = "Pochimon Donjon Myst-re"
horizontal_alignment = 1

[node name="Subtitle" type="Label" parent="Margin/VBox"]
layout_mode = 2
text = "Prototype technique Godot 4"
horizontal_alignment = 1

[node name="NewGameButton" type="Button" parent="Margin/VBox"]
layout_mode = 2
text = "Nouvelle partie"

[node name="LoadButton" type="Button" parent="Margin/VBox"]
layout_mode = 2
text = "Charger"

[connection signal="pressed" from="Margin/VBox/NewGameButton" to="." method="_on_new_game_pressed"]
[connection signal="pressed" from="Margin/VBox/LoadButton" to="." method="_on_load_pressed"]

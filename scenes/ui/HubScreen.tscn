[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/hub_screen.gd" id="1"]

[node name="HubScreen" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1")

[node name="Margin" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/margin_left = 40
theme_override_constants/margin_top = 40
theme_override_constants/margin_right = 40
theme_override_constants/margin_bottom = 40

[node name="VBox" type="VBoxContainer" parent="Margin"]
layout_mode = 2
theme_override_constants/separation = 12

[node name="Title" type="Label" parent="Margin/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 28
text = "Hub du Camp"

[node name="TeamLabel" type="Label" parent="Margin/VBox"]
layout_mode = 2
text = "Équipe"

[node name="InventoryLabel" type="Label" parent="Margin/VBox"]
layout_mode = 2
text = "Inventaire"

[node name="ResourcesLabel" type="Label" parent="Margin/VBox"]
layout_mode = 2
text = "Ressources"

[node name="CampLabel" type="Label" parent="Margin/VBox"]
layout_mode = 2
text = "Camp"

[node name="StatusLabel" type="Label" parent="Margin/VBox"]
layout_mode = 2
text = "Prêt."

[node name="Buttons" type="GridContainer" parent="Margin/VBox"]
layout_mode = 2
columns = 2
theme_override_constants/h_separation = 8
theme_override_constants/v_separation = 8

[node name="EnterDungeon" type="Button" parent="Margin/VBox/Buttons"]
layout_mode = 2
text = "Entrer dans le donjon"

[node name="Rest" type="Button" parent="Margin/VBox/Buttons"]
layout_mode = 2
text = "Se reposer"

[node name="UpgradeFire" type="Button" parent="Margin/VBox/Buttons"]
layout_mode = 2
text = "Améliorer le feu"

[node name="UpgradeTent" type="Button" parent="Margin/VBox/Buttons"]
layout_mode = 2
text = "Améliorer la tente"

[node name="UpgradeScout" type="Button" parent="Margin/VBox/Buttons"]
layout_mode = 2
text = "Former les éclaireurs"

[node name="Save" type="Button" parent="Margin/VBox/Buttons"]
layout_mode = 2
text = "Sauvegarder"

[node name="TitleButton" type="Button" parent="Margin/VBox/Buttons"]
layout_mode = 2
text = "Retour titre"

[connection signal="pressed" from="Margin/VBox/Buttons/EnterDungeon" to="." method="_on_enter_dungeon_pressed"]
[connection signal="pressed" from="Margin/VBox/Buttons/Rest" to="." method="_on_rest_pressed"]
[connection signal="pressed" from="Margin/VBox/Buttons/UpgradeFire" to="." method="_on_upgrade_fire_pressed"]
[connection signal="pressed" from="Margin/VBox/Buttons/UpgradeTent" to="." method="_on_upgrade_tent_pressed"]
[connection signal="pressed" from="Margin/VBox/Buttons/UpgradeScout" to="." method="_on_upgrade_scout_pressed"]
[connection signal="pressed" from="Margin/VBox/Buttons/Save" to="." method="_on_save_pressed"]
[connection signal="pressed" from="Margin/VBox/Buttons/TitleButton" to="." method="_on_title_pressed"]
